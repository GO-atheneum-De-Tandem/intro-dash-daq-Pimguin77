import pandas as pd
import plotly.express as px
from dash import Dash, dcc, html, Input, Output

# CSV laden
df = pd.read_csv(
    "immigrati_00003_stranieri_seriecittaprovenienza (1).csv",
    sep=";",
    encoding="latin-1"
)

# Numeriek maken
df["Numero Immigrati"] = pd.to_numeric(df["Numero Immigrati"], errors="coerce")

# Pivot tabel
df_pivot = df.pivot_table(
    index="Anno",
    columns="Cittadinanza",
    values="Numero Immigrati",
    aggfunc="sum",
    fill_value=0
)

years = df_pivot.index.tolist()

# Dash app maken
app = Dash(__name__)

app.layout = html.Div([
    
    html.H1("Aantal immigranten per land"),

    # Slider voor jaar
    dcc.Slider(
        min=min(years),
        max=max(years),
        step=1,
        value=min(years),
        marks={int(year): str(year) for year in years[::2]},
        id="year-slider"
    ),

    # Grafiek
    dcc.Graph(id="bar-chart")
])

# Callback: update grafiek
@app.callback(
    Output("bar-chart", "figure"),
    Input("year-slider", "value")
)
def update_graph(selected_year):

    data = df_pivot.loc[selected_year].sort_values(ascending=False).head(10)

    fig = px.bar(
        x=data.values,
        y=data.index,
        orientation='h',
        text=data.values,
        title=f"Aantal immigranten - {selected_year}"
    )

    fig.update_layout(
        xaxis_title="Aantal immigranten",
        yaxis_title="Land",
        yaxis=dict(autorange="reversed")  # grootste bovenaan
    )

    return fig

# Run app
if __name__ == "__main__":
    app.run(debug=True)
